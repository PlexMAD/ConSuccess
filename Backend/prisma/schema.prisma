generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          Int                  @id @default(autoincrement())
  username                    String               @unique
  passwordHash                String               @map("password_hash")
  avatar                      String?
  createdAt                   DateTime             @default(now()) @map("created_at")
  favorites                   Favorite[]
  likes                       Like[]
  posts                       Post[]
  role                        Role                 @default(USER)
  teacherApplications         TeacherApplication[] @relation("TeacherApplicationUser")
  reviewedTeacherApplications TeacherApplication[] @relation("TeacherApplicationReviewer")

  @@map("users")
}

enum Role {
  USER
  TEACHER
  MODERATOR
  ADMIN
}

enum TeacherApplicationStatus {
  PENDING
  APPROVED
}

model University {
  id       Int       @id @default(autoincrement())
  name     String
  cityId   Int       @map("city_id")
  avatar   String?
  city     City      @relation(fields: [cityId], references: [id])
  subjects Subject[]
}

model City {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  universities University[]
}

model Subject {
  id           Int        @id @default(autoincrement())
  name         String
  universityId Int        @map("university_id")
  posts        Post[]
  university   University @relation(fields: [universityId], references: [id])

  @@map("subjects")
}

model Post {
  id          Int          @id @default(autoincrement())
  userId      Int          @map("user_id")
  subjectId   Int?         @map("subject_id")
  title       String
  body        String
  visible     Boolean      @default(true)
  isPrivate   Boolean      @default(false) @map("is_private")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  attachments Attachment[]
  favorites   Favorite[]
  likes       Like[]
  subject     Subject?     @relation(fields: [subjectId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Attachment {
  id         Int      @id @default(autoincrement())
  postId     Int      @map("post_id")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  url        String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Favorite {
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("favorites")
}

model Like {
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("likes")
}

model TeacherApplication {
  id           Int                      @id @default(autoincrement())
  userId       Int                      @unique @map("user_id")
  fullName     String                   @map("full_name")
  documentUrl  String                   @map("document_url")
  status       TeacherApplicationStatus @default(PENDING)
  createdAt    DateTime                 @default(now()) @map("created_at")
  reviewedAt   DateTime?                @map("reviewed_at")
  reviewedById Int?                     @map("reviewed_by_id")
  reviewer     User?                    @relation("TeacherApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  user         User                     @relation("TeacherApplicationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_applications")
}
