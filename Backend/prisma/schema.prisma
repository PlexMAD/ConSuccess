// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String

  users User[]
}

model User {
  id           Int        @id @default(autoincrement())
  username     String
  passwordHash String     @map("password_hash")
  roleId       Int        @map("role_id")
  createdAt    DateTime   @default(now()) @map("created_at")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posts        Post[]
  favorites    Favorite[]

  @@map("users")
}

model University {
  id       Int       @id @default(autoincrement())
  name     String
  city     String

  subjects Subject[]
}

model Subject {
  id           Int        @id @default(autoincrement())
  name         String
  universityId Int        @map("university_id")

  university   University @relation(fields: [universityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posts        Post[]

  @@map("subjects")
}

model Post {
  id        Int          @id @default(autoincrement())
  userId    Int          @map("user_id")
  subjectId Int?         @map("subject_id")
  title     String
  body      String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  subject     Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  attachments Attachment[]
  favorites   Favorite[]

  @@map("posts")
}

model Attachment {
  id         Int      @id @default(autoincrement())
  postId     Int      @map("post_id")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  url        String

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("attachments")
}

model Favorite {
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([userId, postId])
  @@map("favorites")
}